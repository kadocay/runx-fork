{
  "schema": "runx.tool.manifest.v1",
  "name": "sourcey.package",
  "description": "Package a completed Sourcey run into a reusable Sourcey packet.",
  "source": {
    "type": "cli-tool",
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "inputs": {
    "discovery_report": {
      "type": "json",
      "required": true,
      "description": "Discovery report emitted by the Sourcey discover step.",
      "artifact": true
    },
    "doc_bundle": {
      "type": "json",
      "required": true,
      "description": "Doc bundle emitted by the Sourcey author step.",
      "artifact": true
    },
    "evaluation_report": {
      "type": "json",
      "required": true,
      "description": "Evaluation report emitted by the critique step.",
      "artifact": true
    },
    "project_brief": {
      "type": "json",
      "required": false,
      "description": "Optional grounded brief supplied to the Sourcey run.",
      "artifact": true
    },
    "revision_bundle": {
      "type": "json",
      "required": true,
      "description": "Revision bundle emitted by the revise step.",
      "artifact": true
    },
    "sourcey_build_report": {
      "type": "json",
      "required": true,
      "description": "Sourcey build report emitted by sourcey.build.",
      "artifact": true
    },
    "sourcey_verification_proof": {
      "type": "json",
      "required": true,
      "description": "Verification proof emitted by sourcey.verify.",
      "artifact": true
    }
  },
  "scopes": [
    "sourcey.verify"
  ],
  "runx": {
    "artifacts": {
      "wrap_as": "sourcey_packet"
    }
  },
  "runtime": {
    "command": "node",
    "args": [
      "./run.mjs"
    ]
  },
  "output": {
    "packet": "runx.sourcey.packet.v1",
    "wrap_as": "sourcey_packet"
  },
  "source_hash": "sha256:e36f2eaee008b5d04a6d5b799fa21a0e9450f48ddc37e5f7422197340a095151",
  "schema_hash": "sha256:975669ce4f792acc392b93ec9cc6010cb95a9dacff5dbdcc420e9b64448d8dd4",
  "toolkit_version": "0.1.4"
}
